# Wren Backend Configuration
# Copy to .env and fill in real values. Do NOT commit .env.

# Server
PORT=3000
NODE_ENV=development

# Security (REQUIRED in production — server refuses to boot with defaults)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=30d

# Seed owner account
OWNER_EMAIL=owner@wren.ide
OWNER_PASSWORD=change-me

# AI provider — set ONE. Priority: Anthropic > OpenAI > Gemini.
# If none is set, the deterministic local engine is used.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
